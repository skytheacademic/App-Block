# Normalize line endings across machines. Store as LF, check out native.
* text=auto eol=lf

# Windows-only scripts stay CRLF
*.bat  text eol=crlf
*.cmd  text eol=crlf

# Gradle wrapper
gradlew      text eol=lf
gradlew.bat  text eol=crlf

# Binary assets
*.jar      binary
*.keystore binary
*.jks      binary
*.png      binary
*.webp     binary
*.ttf      binary
